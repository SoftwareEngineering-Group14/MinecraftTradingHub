############################################################
# HOW TO USE:
# 1. Create copy of this file
# 2. Rename the copy to `.env.local`
# 3. Replace the placeholder values below with your real keys
#
# Get your Supabase credentials from:
# Supabase Dashboard → Project Settings → API


NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLIC_ANON_KEY

# Server-only (never NEXT_PUBLIC_). Found in Supabase Dashboard → Project Settings → API → service_role key.
# Required for admin operations that bypass RLS (join request approval, purchases).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
